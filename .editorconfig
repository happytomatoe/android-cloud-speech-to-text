# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true

[*.{kt,kts}]
indent_size = 4

[*.{xml,json,yml,yaml}]
indent_size = 2

[*.md]
indent_size = 4

[*.sh]
end_of_line = lf

[Makefile]
indent_style = tab
