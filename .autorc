{
  "plugins": [
    "git-tag",
    ["upload-assets", { "assets": ["android/app/build/outputs/apk/release/app-release.apk"] }],
    "released",
    ["exec", {
      "version": "./scripts/update-version.sh $ARG_0"
    }]
  ],
  "labels": [
    { "releaseType": "major", "name": "major" },
    { "releaseType": "major", "name": "breaking" },
    { "releaseType": "minor", "name": "minor" },
    { "releaseType": "minor", "name": "enhancement" },
    { "releaseType": "patch", "name": "patch" },
    { "releaseType": "patch", "name": "bug" },
    { "releaseType": "skip", "name": "skip-release" },
    { "releaseType": "release", "name": "release" }
  ]
}
