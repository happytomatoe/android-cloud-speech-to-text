#!/usr/bin/env bash
# Reject commits whose message contains a "Co-Authored-By:" trailer.
# This keeps AI-assistant co-author trailers out of the history (and PRs).
set -e

commit_msg_file="$1"
if grep -qiE '^Co-Authored-By:' "$commit_msg_file"; then
    echo "ERROR: commit messages must not contain a 'Co-Authored-By:' trailer." >&2
    echo "Remove the 'Co-Authored-By:' line and try again." >&2
    exit 1
fi
