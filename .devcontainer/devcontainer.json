{
  "name": "Whisper To Input (Android)",

  // postCreateCommand is split into bisect halves (see NOTE below).
  // HALF 1 (this revision): base runtimes + pi coding agent. Fast (~2-3 min).
  // HALF 2 (next): Android SDK, emulator, just, hs, pre-commit, project hooks.
  // pi is installed into a user-owned npm prefix (~/.npm-global) so it lands on
  // PATH without sudo (the default universal image's nvm prefix is root-owned).
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y --no-install-recommends openjdk-17-jdk-headless unzip curl git ca-certificates python3-pip && npm config set prefix \"$HOME/.npm-global\" && export PATH=\"$HOME/.npm-global/bin:$PATH\" && npm install -g @earendil-works/pi-coding-agent && printf 'export PATH=\"$HOME/.npm-global/bin:$PATH\"\\n' >> \"$HOME/.bashrc\"",

  "customizations": {
    "vscode": {
      "extensions": [
        "fwcd.kotlin",
        "editorconfig.editorconfig",
        "github.vscode-pull-request-github",
        "earendil-works.pi-coding-agent"
      ]
    }
  }

  // NOTE — emulator / E2E:
  //   The default 2-vCPU Codespace has no hardware KVM, so the Android emulator
  //   (and `just test-e2e*`) will NOT run there. For E2E you need a 4+ vCPU
  //   machine type (paid). Build + `just test` (Robolectric/JVM) work everywhere.
  //   To require such a machine, add:  "hostRequirements": { "cpus": 4 }
  //
  // NOTE — DEEPGRAM_KEY (needed only for E2E):
  //   Add it as a Codespace secret (repo or user settings) and forward it to the
  //   codespace. Devcontainer.json has no secrets field; configure it in the
  //   Codespaces UI (Settings > Codespaces > Secrets).
  //
  // NOTE — no custom `image` / `sshd` feature on purpose:
  //   GitHub Codespaces provides native SSH tunneling only on the default
  //   universal image. Pinning a custom `image` (or adding the `sshd`
  //   devcontainer feature) breaks `gh codespace ssh` (Permission denied).
  //   All tooling is installed by postCreateCommand, so we deliberately use the
  //   default image and keep this file minimal + bisectable.
}
