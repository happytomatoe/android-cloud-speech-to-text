{
  "name": "Whisper To Input (Android)",

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "fwcd.kotlin",
        "editorconfig.editorconfig",
        "github.vscode-pull-request-github",
        "earendil-works.pi-coding-agent"
      ]
    }
  }

  // NOTE — emulator / E2E:
  //   The default 2-vCPU Codespace has no hardware KVM, so the Android emulator
  //   (and `just test-e2e*`) will NOT run there. For E2E you need a 4+ vCPU
  //   machine type (paid). Build + `just test` (Robolectric/JVM) work everywhere.
  //   To require such a machine, add:  "hostRequirements": { "cpus": 4 }
  //
  // NOTE — DEEPGRAM_KEY (needed only for E2E):
  //   Add it as a Codespace secret (repo or user settings) and forward it to the
  //   codespace. Devcontainer.json has no secrets field; configure it in the
  //   Codespaces UI (Settings > Codespaces > Secrets).
  //
  // NOTE — no custom `image` / `sshd` feature on purpose:
  //   GitHub Codespaces provides native SSH tunneling only on the default
  //   universal image. Pinning a custom `image` (or adding the `sshd`
  //   devcontainer feature) breaks `gh codespace ssh` (Permission denied).
  //   All tooling (JDK, Android SDK, pi, …) is installed by setup.sh, so we
  //   deliberately use the default image and keep this file minimal.
}
